<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Why Not Here?"
        Width="820"
        Height="660"
        MinWidth="720"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#FDF6E3"
        Foreground="#073642"
        FontFamily="Segoe UI"
        FontSize="13">

    <Window.Resources>
        <SolidColorBrush x:Key="Brush.WindowBackground" Color="#FDF6E3"/>
        <SolidColorBrush x:Key="Brush.Surface" Color="#EEE8D5"/>
        <SolidColorBrush x:Key="Brush.Overlay" Color="#E4DDC6"/>
        <SolidColorBrush x:Key="Brush.Accent" Color="#268BD2"/>
        <SolidColorBrush x:Key="Brush.Text" Color="#073642"/>
        <SolidColorBrush x:Key="Brush.Subtext" Color="#4A5C61"/>
        <SolidColorBrush x:Key="Brush.Success" Color="#728A02"/>
        <SolidColorBrush x:Key="Brush.Warning" Color="#9C7700"/>
        <SolidColorBrush x:Key="Brush.Danger" Color="#C32B28"/>
        <SolidColorBrush x:Key="Brush.Border" Color="#BFB6A0"/>
        <SolidColorBrush x:Key="Brush.Selection" Color="#CFE6F7"/>
        <SolidColorBrush x:Key="Brush.AccentHover" Color="#1E268BD2"/>
        <SolidColorBrush x:Key="Brush.DangerHover" Color="#1EC32B28"/>
        <SolidColorBrush x:Key="Brush.BlockerSurface" Color="#F5E4DC"/>
        <SolidColorBrush x:Key="Brush.BlockerBorder" Color="#D58A7D"/>
        <SolidColorBrush x:Key="Brush.SuccessSurface" Color="#E8EED1"/>
        <SolidColorBrush x:Key="Brush.SuccessBorder" Color="#A8B45D"/>
        <SolidColorBrush x:Key="Brush.PossibleSurface" Color="#F3EACD"/>
        <SolidColorBrush x:Key="Brush.PossibleBorder" Color="#C5A95E"/>

        <FontFamily x:Key="Font.BaseFamily">Segoe UI</FontFamily>
        <sys:Double x:Key="Font.BaseSize">13</sys:Double>
        <sys:Double x:Key="Font.TitleSize">20</sys:Double>
        <sys:Double x:Key="Font.SectionSize">14</sys:Double>
        <sys:Double x:Key="Font.StatusSize">11</sys:Double>

        <Style x:Key="Button.Primary" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Brush.Accent}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.WindowBackground}"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Button.Secondary" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Accent}"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Button.CompactSecondary" TargetType="Button" BasedOn="{StaticResource Button.Secondary}">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="TextBox.Standard" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource Brush.WindowBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Height" Value="34"/>
        </Style>

        <Style x:Key="ComboBox.Standard" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource Brush.WindowBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="56"
                            Height="56"
                            Background="{StaticResource Brush.Accent}"
                            CornerRadius="5"
                            Margin="0,0,16,0">
                        <TextBlock Text="?"
                                   Foreground="{StaticResource Brush.WindowBackground}"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Why Not Here?"
                                   FontSize="{StaticResource Font.TitleSize}"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Brush.Text}"/>
                        <TextBlock Text="Visibility diagnostics for Revit views"
                                   Foreground="{StaticResource Brush.Subtext}"
                                   FontSize="14"/>
                    </StackPanel>

                </Grid>

                <Border Grid.Row="1"
                        Background="{StaticResource Brush.Surface}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="16"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TxtElementTitle"
                                   Grid.Row="0"
                                   Grid.Column="0"
                                   Text="Selected element"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.Text}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,16,0"/>
                        <TextBlock x:Name="TxtElementSubtitle"
                                   Grid.Row="1"
                                   Grid.Column="0"
                                   Text="Host-model element"
                                   Foreground="{StaticResource Brush.Subtext}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                        <StackPanel x:Name="PanelHeaderTarget"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Grid.RowSpan="2"
                                    Visibility="Collapsed"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="24,0,0,0">
                            <TextBlock Text="Target view"
                                       Foreground="{StaticResource Brush.Subtext}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right"/>
                            <TextBlock x:Name="TxtHeaderTargetView"
                                       Text=""
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.Text}"
                                       TextWrapping="Wrap"
                                       MaxWidth="420"
                                       HorizontalAlignment="Right"
                                       TextAlignment="Right"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid x:Name="InputPanel" Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource Brush.Surface}"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Where is it missing?"
                                       FontSize="{StaticResource Font.SectionSize}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.Text}"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="Choose the view where you expected to see the selected element."
                                       Foreground="{StaticResource Brush.Subtext}"
                                       FontSize="{StaticResource Font.StatusSize}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"/>
                            <TextBlock x:Name="TxtTargetSummary"
                                       Text="Selected view: none"
                                       Foreground="{StaticResource Brush.Subtext}"
                                       FontSize="{StaticResource Font.StatusSize}"
                                       Margin="0,0,0,10"/>

                            <StackPanel x:Name="SearchPanel">
                                <TextBlock Text="Search views"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Brush.Text}"
                                           Margin="0,0,0,6"/>
                                <TextBox x:Name="TxtSearch"
                                         Style="{StaticResource TextBox.Standard}"
                                         Text=""
                                         Margin="0,0,0,8"/>
                                <TextBlock Text="Missing from view"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Brush.Text}"
                                           Margin="0,0,0,6"/>
                                <ComboBox x:Name="ComboViews"
                                          Style="{StaticResource ComboBox.Standard}"/>
                                <TextBlock Text="Only graphical model views are listed."
                                           Foreground="{StaticResource Brush.Subtext}"
                                           FontSize="{StaticResource Font.StatusSize}"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="ResultsPanel"
                      Grid.Row="2"
                      Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="TxtResultMarker"
                                       Text="!"
                                       Width="28"
                                       Height="28"
                                       Background="{StaticResource Brush.Accent}"
                                       Foreground="{StaticResource Brush.WindowBackground}"
                                       FontWeight="Bold"
                                       FontSize="18"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <TextBlock x:Name="TxtBlockerCount"
                                       Text="0 blockers remaining"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource Brush.Text}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel x:Name="PanelPossibleSummary"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed"
                                    Margin="18,0,0,0">
                            <TextBlock x:Name="TxtPossibleSummaryMarker"
                                       Text="?"
                                       Width="28"
                                       Height="28"
                                       Background="{StaticResource Brush.Warning}"
                                       Foreground="{StaticResource Brush.WindowBackground}"
                                       FontWeight="Bold"
                                       FontSize="18"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <TextBlock x:Name="TxtPossibleSummary"
                                       Text="0 possible issues"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource Brush.Text}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="PanelConfirmed"
                                Grid.Row="1"/>

                    <Border x:Name="BorderPossibleIssues"
                            Grid.Row="2"
                            Background="{StaticResource Brush.Surface}"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="10"
                            Margin="0,0,0,8">
                        <StackPanel>
                            <Button x:Name="BtnPossibleToggle"
                                    Style="{StaticResource Button.CompactSecondary}"
                                    HorizontalAlignment="Stretch">
                                <DockPanel LastChildFill="True">
                                    <TextBlock x:Name="TxtPossibleCount"
                                               Text="Possible issues (0)"
                                               DockPanel.Dock="Left"
                                               FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TxtPossibleChevron"
                                               Text="v"
                                               DockPanel.Dock="Right"
                                               HorizontalAlignment="Right"/>
                                </DockPanel>
                            </Button>
                            <TextBlock x:Name="TxtPossibleHelp"
                                       Text="These are conditions that may affect visibility, but Revit did not provide enough evidence to confirm them as blockers."
                                       Foreground="{StaticResource Brush.Subtext}"
                                       FontSize="{StaticResource Font.StatusSize}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                            <StackPanel x:Name="PanelPossibleItems"
                                        Margin="0,8,0,0"
                                        Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="3"
                            Background="{StaticResource Brush.Surface}"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="10">
                        <StackPanel>
                            <Button x:Name="BtnPassedToggle"
                                    Style="{StaticResource Button.CompactSecondary}"
                                    HorizontalAlignment="Stretch">
                                <DockPanel LastChildFill="True">
                                    <TextBlock x:Name="TxtPassedCount"
                                               Text="Passed checks (0)"
                                               DockPanel.Dock="Left"
                                               FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TxtPassedChevron"
                                               Text="v"
                                               DockPanel.Dock="Right"
                                               HorizontalAlignment="Right"/>
                                </DockPanel>
                            </Button>
                            <StackPanel x:Name="PanelPassedItems"
                                        Margin="0,8,0,0"
                                        Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                </Grid>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="1"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,1,0,0"
                Background="{StaticResource Brush.WindowBackground}"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatus"
                           Grid.Column="0"
                           Text="Choose the view where the element is missing."
                           TextWrapping="Wrap"
                           FontSize="{StaticResource Font.StatusSize}"
                           Foreground="{StaticResource Brush.Subtext}"
                           VerticalAlignment="Center"/>
                <Button x:Name="BtnBack"
                        Grid.Column="1"
                        Content="Back"
                        Width="110"
                        Visibility="Collapsed"
                        Style="{StaticResource Button.Secondary}"/>
                <Button x:Name="BtnCancel"
                        Grid.Column="3"
                        Content="Cancel"
                        Width="110"
                        Style="{StaticResource Button.Secondary}"/>
                <Button x:Name="BtnAnalyze"
                        Grid.Column="5"
                        Content="Analyze"
                        Width="120"
                        Style="{StaticResource Button.Primary}"/>
                <Button x:Name="BtnRecheck"
                        Grid.Column="3"
                        Content="Recheck"
                        Width="110"
                        Visibility="Collapsed"
                        Style="{StaticResource Button.Secondary}"/>
                <Button x:Name="BtnClose"
                        Grid.Column="5"
                        Content="Close"
                        Width="120"
                        Visibility="Collapsed"
                        Style="{StaticResource Button.Primary}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
